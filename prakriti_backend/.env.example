# SQLAlchemy async database URL
DATABASE_URL=sqlite+aiosqlite:///./test.db

# Redis cache/session URL (optional, app falls back if unavailable)
REDIS_URL=redis://localhost:6379/0

# JWT signing secret (set a strong random value in production)
JWT_SECRET=changeme-32chars

# Google Gemini API key used for AI recommendations and explanations
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY

# OpenWeather API key for weather + AQI enrichment
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY

# Optional Twitter/X token for social signal ingestion
TWITTER_BEARER_TOKEN=

# Runtime environment: development | production
ENVIRONMENT=development

# Comma-separated frontend origins for CORS
CORS_ORIGINS=http://localhost:3000